<% layout("/layouts/boilerplate") %>

<div class="container py-5">
    <div class="row">
        <!-- Image Section -->
        <div class="col-lg-6 mb-4">
            <div class="card bg-dark border-0 shadow-lg rounded-4 overflow-hidden">
                <img src="<%= listing.image.url %>" class="img-fluid" alt="<%= listing.title %>" style="max-height: 500px; object-fit: cover;">
            </div>
        </div>

        <!-- Content Section -->
        <div class="col-lg-6">
            <div class="p-4 bg-slate rounded-4 shadow-sm h-100">
                <h2 class="section-title text-start mb-2"><%= listing.title %></h2>
                <p class="text-secondary mb-4">
                    <i class="fa-solid fa-location-dot me-2"></i><%= listing.location %>, <%= listing.country %>
                </p>
                <hr class="border-secondary opacity-25">
                
                <h4 class="text-light mt-4">Description</h4>
                <p class="text-gray mb-4"><%= listing.description %></p>
                
                <div class="mb-5">
                    <span class="fs-3 fw-bold text-primary">&#8377; <%= listing.price.toLocaleString("en-IN") %></span>
                    <span class="text-secondary"> / night</span>
                </div>

                <div class="d-flex gap-3">
                    <a href="/listings/<%= listing._id %>/edit" class="btn btn-primary px-4">
                        <i class="fa-solid fa-pen-to-square me-2"></i>Edit Property
                    </a>
                    <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE">
                        <button class="btn btn-outline-danger px-4">
                            <i class="fa-solid fa-trash me-2"></i>Delete Property
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- Feedback Section -->
    <div class="row mt-5">
        <div class="col-lg-8 offset-lg-2">
            <div class="card bg-slate border-0 p-4 rounded-4">
                <h4 class="text-light mb-4"><i class="fa-solid fa-star me-2 text-warning"></i>Leave a Review</h4>
                <form action="/listings/<%= listing._id %>" method="POST">
                    <div class="mb-4">
                        <label class="form-label text-gray">Rating (1-5)</label>
                        <input type="range" min="1" max="5" name="review[rating]" class="form-range custom-range">
                    </div>
                    <div class="mb-4">
                        <label class="form-label text-gray">Your Experience</label>
                        <textarea name="review[comment]" class="form-control bg-navy border-0 text-light py-3" rows="4" placeholder="Share your thoughts..." required></textarea>
                    </div>
                    <button class="btn btn-primary">Post Review</button>
                </form>
            </div>
        </div>
    </div>
</div>