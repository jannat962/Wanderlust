<% layout("/layouts/boilerplate") %>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card bg-slate border-0 p-4 rounded-4 shadow">
                <h3 class="text-light mb-4"><i class="fa-solid fa-pen-to-square me-2 text-primary"></i>Edit Property Listing</h3>
                
                <form method="POST" action="/listings/<%= listing._id %>?_method=PUT" class="needs-validation" novalidate>
                    <div class="mb-4">
                        <label class="form-label text-gray">Property Title</label>
                        <input name="listing[title]" value="<%= listing.title %>" type="text" class="form-control bg-navy border-0 text-light py-2" required>
                    </div>

                    <div class="mb-4">
                        <label class="form-label text-gray">Description</label>
                        <textarea name="listing[description]" class="form-control bg-navy border-0 text-light py-2" rows="5" required><%= listing.description %></textarea>
                    </div>

                    <div class="mb-4">
                        <label class="form-label text-gray">Image URL</label>
                        <input name="listing[image][url]" value="<%= listing.image.url %>" type="text" class="form-control bg-navy border-0 text-light py-2">
                        <small class="text-secondary">Paste a new image link to change the cover photo</small>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-4">
                            <label class="form-label text-gray">Price (per night)</label>
                            <div class="input-group">
                                <span class="input-group-text bg-navy border-0 text-gray">&#8377;</span>
                                <input name="listing[price]" value="<%= listing.price %>" type="number" class="form-control bg-navy border-0 text-light py-2" required>
                            </div>
                        </div>
                        <div class="col-md-6 mb-4">
                            <label class="form-label text-gray">Country</label>
                            <input name="listing[country]" value="<%= listing.country %>" type="text" class="form-control bg-navy border-0 text-light py-2" required>
                        </div>
                    </div>

                    <div class="mb-5">
                        <label class="form-label text-gray">Location</label>
                        <input name="listing[location]" value="<%= listing.location %>" type="text" class="form-control bg-navy border-0 text-light py-2" required>
                    </div>

                    <div class="d-flex gap-3">
                        <button class="btn btn-primary px-5">Save Changes</button>
                        <a href="/listings/<%= listing._id %>" class="btn btn-outline-secondary px-4">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>