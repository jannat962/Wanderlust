  <% layout("/layouts/boilerplate") %>
  <body>
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card bg-slate border-0 p-4 rounded-4 shadow">
                <h3 class="text-light mb-4"><i class="fa-solid fa-plus-circle me-2 text-primary"></i>Create a New Listing</h3>
                
                <form method="POST" action="/listings" class="needs-validation" novalidate>
                    <div class="mb-4">
                        <label class="form-label text-gray">Property Title</label>
                        <input name="listing[title]" placeholder="Add a catchy title" type="text" class="form-control bg-navy border-0 text-light py-2" required>
                    </div>

                    <div class="mb-4">
                        <label class="form-label text-gray">Description</label>
                        <textarea name="listing[description]" class="form-control bg-navy border-0 text-light py-2" rows="5" placeholder="Enter description" required></textarea>
                    </div>

                    <div class="mb-4">
                        <label class="form-label text-gray">Image URL</label>
                        <input name="listing[image][url]" placeholder="enter image URL/Link" type="text" class="form-control bg-navy border-0 text-light py-2">
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-4">
                            <label class="form-label text-gray">Price (per night)</label>
                            <div class="input-group">
                                <span class="input-group-text bg-navy border-0 text-gray">&#8377;</span>
                                <input name="listing[price]" placeholder="enter price" type="number" class="form-control bg-navy border-0 text-light py-2" required>
                            </div>
                        </div>
                        <div class="col-md-6 mb-4">
                            <label class="form-label text-gray">Country</label>
                            <input name="listing[country]" placeholder="enter country" type="text" class="form-control bg-navy border-0 text-light py-2" required>
                        </div>
                    </div>

                    <div class="mb-5">
                        <label class="form-label text-gray">Location</label>
                        <input name="listing[location]" placeholder="enter location" type="text" class="form-control bg-navy border-0 text-light py-2" required>
                    </div>

                    <div class="d-flex gap-3">
                        <button class="btn btn-primary px-5">Add Listing</button>
                        <a href="/listings" class="btn btn-outline-secondary px-4">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
  </div>
</div>
  </body>
<!-- </html> -->