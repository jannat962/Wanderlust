<% layout("/layouts/boilerplate") %>

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-5">
        <h2 class="section-title text-start m-0">Owner Dashboard</h2>
        <a href="/listings/new" class="btn btn-primary rounded-pill px-4">
            <i class="fa-solid fa-plus me-2"></i>Add New Listing
        </a>
    </div>

    <div class="row">
        <% if(allListings.length === 0) { %>
            <div class="col-12 text-center py-5">
                <div class="bg-slate p-5 rounded-4 shadow-sm">
                    <i class="fa-solid fa-house-chimney-user fa-3x text-secondary mb-4"></i>
                    <h3 class="text-light">No Listings Found</h3>
                    <p class="text-gray mb-4">You haven't added any properties yet. Start your journey by creating your first listing!</p>
                    <a href="/listings/new" class="btn btn-primary">Create Your First Listing</a>
                </div>
            </div>
        <% } %>

        <% for(let listing of allListings) { %>
            <div class="col-lg-4 col-md-6 mb-4">
                <div class="card h-100 bg-slate border-0 shadow-sm rounded-4 overflow-hidden listing-card">
                    <div class="position-relative">
                        <img src="<%= listing.image.url %>" class="card-img-top" alt="<%= listing.title %>" style="height: 200px; object-fit: cover;">
                        <div class="position-absolute top-0 end-0 m-3">
                            <span class="badge bg-primary rounded-pill px-3 py-2 shadow-sm">
                                &#8377; <%= listing.price.toLocaleString("en-IN") %>
                            </span>
                        </div>
                    </div>
                    <div class="card-body p-4">
                        <h5 class="card-title text-light mb-2"><%= listing.title %></h5>
                        <p class="card-text text-gray mb-3">
                            <i class="fa-solid fa-location-dot me-2 text-primary"></i><%= listing.location %>
                        </p>
                        <div class="d-flex gap-2">
                            <a href="/listings/<%= listing._id %>" class="btn btn-sm btn-outline-light flex-grow-1">View</a>
                            <a href="/listings/<%= listing._id %>/edit" class="btn btn-sm btn-primary flex-grow-1">Edit</a>
                            <form action="/listings/<%= listing._id %>?_method=DELETE" method="POST" class="flex-grow-1">
                                <button class="btn btn-sm btn-danger w-100">Delete</button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        <% } %>
    </div>
</div>
