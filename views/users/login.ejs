<% layout("/layouts/boilerplate") %>

<div class="row mt-3">
    <h1 class="col-6 offset-3 section-title">Login</h1>
    <div class="col-6 offset-3">
        <div class="card bg-slate border-0 p-4 rounded-4 shadow">
            <form action="/login" method="POST" class="needs-validation" novalidate>
                <div class="mb-3">
                    <label for="username" class="form-label text-gray">Username</label>
                    <input name="username" id="username" type="text" class="form-control bg-navy border-0 text-light py-2" placeholder="Enter username" required>
                </div>
                <div class="mb-3">
                    <label for="password" class="form-label text-gray">Password</label>
                    <input name="password" id="password" type="password" class="form-control bg-navy border-0 text-light py-2" placeholder="Enter password" required>
                </div>
                <button class="btn btn-primary w-100">Login</button>
            </form>
            <div class="mt-3 text-center">
                <span class="text-secondary">New to Wanderlust? </span>
                <a href="/signup" class="text-primary text-decoration-none">Create an account</a>
            </div>
        </div>
    </div>
</div>
