<% layout("/layouts/boilerplate") %>

<div class="row mt-3">
    <h1 class="col-6 offset-3 section-title">Sign Up on Wanderlust</h1>
    <div class="col-6 offset-3">
        <div class="card bg-slate border-0 p-4 rounded-4 shadow">
            <form action="/signup" method="POST" class="needs-validation" novalidate>
                <div class="mb-3">
                    <label for="username" class="form-label text-gray">Username</label>
                    <input name="username" id="username" type="text" class="form-control bg-navy border-0 text-light py-2" required>
                    <div class="valid-feedback">Looks good!</div>
                </div>
                <div class="mb-3">
                    <label for="email" class="form-label text-gray">Email</label>
                    <input name="email" id="email" type="email" class="form-control bg-navy border-0 text-light py-2" required>
                </div>
                <div class="mb-3">
                    <label for="password" class="form-label text-gray">Password</label>
                    <input name="password" id="password" type="password" class="form-control bg-navy border-0 text-light py-2" required>
                </div>
                <button class="btn btn-primary w-100">Sign Up</button>
            </form>
            <div class="mt-3 text-center">
                <span class="text-secondary">Already have an account? </span>
                <a href="/login" class="text-primary text-decoration-none">Login</a>
            </div>
        </div>
    </div>
</div>
